<header role="banner">
  <div>
    <div>
      <a href="/" aria-label="Home - {{ site.name }}">
        {{ site.name }}
      </a>
    </div>
    
    <div>
      <input type="checkbox" 
             id="navigation-toggle" 
             aria-label="Toggle navigation menu">
      <label for="navigation-toggle">
        <span></span>
        <span>Toggle navigation menu</span>
      </label>
      
      <nav role="navigation" aria-label="Main navigation">
        {% if navigation and navigation.length %}
          <ul role="list">
            {% for item in navigation %}
              <li>
                <a href="{{ item.url }}" 
                   {% if item.url == page.url %}aria-current="page"{% endif %}
                   {% if item.external %}target="_blank" rel="noopener noreferrer" aria-describedby="external-link-desc"{% endif %}>
                  {{ item.title }}
                  {% if item.external %}
                    <span> (opens in new window)</span>
                  {% endif %}
                </a>
              </li>
            {% endfor %}
          </ul>
          <div id="external-link-desc">External links open in a new window</div>
        {% endif %}
      </nav>
    </div>
  </div>
</header>