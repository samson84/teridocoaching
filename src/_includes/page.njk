---
layout: base.njk
---
<article role="article" class="page-shell motion-fade-in">
  {% if title %}
    <header class="page-header">
      <h1 id="page-title" class="page-title">{{ title }}</h1>
      {% if description %}
        <p class="page-description">{{ description }}</p>
      {% endif %}
    </header>
  {% endif %}

  <section role="region" {% if title %}aria-labelledby="page-title"{% else %}aria-label="Page content"{% endif %} class="prose-flow">
    {{ content | safe }}
  </section>
</article>